rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && 
        firestore.get(
          /databases/(default)/documents/users/$(request.auth.uid)
        ).data.userRole == 'admin';
    }

    // PROFILE PHOTOS
    match /profile-images/{userId}/{fileName} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && 
        request.auth.uid == userId &&
        request.resource.size < 5 * 1024 * 1024 &&
        request.resource.contentType.matches('image/.*');
    }

    // THREAD IMAGES
    // Any signed in member can upload
    match /thread-images/{fileName} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() &&
        request.resource.size < 10 * 1024 * 1024 &&
        request.resource.contentType.matches('image/.*');
    }

    // MESSAGE IMAGES
    match /message-images/{fileName} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() &&
        request.resource.size < 10 * 1024 * 1024 &&
        request.resource.contentType.matches('image/.*');
    }

    // TOOL IMAGES
    // Admin only upload
    match /tool-images/{fileName} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // LESSON IMAGES
    match /lesson-images/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isAdmin() &&
        request.resource.size < 5 * 1024 * 1024 &&
        request.resource.contentType.matches('image/.*');
    }

    // COURSE COVERS
    match /course-covers/{fileName} {
      allow read: if true;
      allow write: if isAdmin() &&
        request.resource.size < 5 * 1024 * 1024 &&
        request.resource.contentType.matches('image/.*');
    }

    // COURSE CONTENT
    match /course-content/{fileName} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // VOICE TOOL AUDIO — written server-side only, readable by owner
    match /voice-audio/{userId}/{fileName} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow write: if false;
    }

    // HUB LOGOS — uploaded by hub owners, publicly readable
    match /hub-logos/{userId}/{fileName} {
      allow read: if true;
      allow write: if isSignedIn() &&
        request.auth.uid == userId &&
        request.resource.size < 2 * 1024 * 1024 &&
        request.resource.contentType.matches('image/.*');
    }

    // GENERAL ASSETS
    match /assets/{fileName} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}