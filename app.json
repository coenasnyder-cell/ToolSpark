{
  "expo": {
    "name": "ToolSpark",
    "slug": "toolspark",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "toolspark",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mycompany.toolspark",
      "associatedDomains": [
        "applinks:toolspark.co"
      ],
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "We need access to your photo library to upload a profile picture.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.mycompany.toolspark",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#F5F3EF"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "toolspark.co",
              "pathPrefix": "/auth-action"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://toolspark.co"
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F5F3EF",
          "dark": {
            "backgroundColor": "#1A1916"
          }
        }
      ],
      "expo-web-browser",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.82966513396-80ak77ileqnvd3i5objrdu58eo4nc8ii"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": "https://toolspark.co"
      },
      "eas": {
        "projectId": "YOUR_EAS_PROJECT_ID"
      }
    }
  }
}
