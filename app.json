{
  "expo": {
    "name": "ToolSpark",
    "slug": "toolspark",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "toolspark",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mycompany.toolspark"
    },
    "android": {
      "package": "com.mycompany.toolspark",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#0C0B09"
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://toolspark.co"
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0C0B09",
          "dark": {
            "backgroundColor": "#0C0B09"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": "https://toolspark.co"
      },
      "eas": {
        "projectId": "YOUR_EAS_PROJECT_ID"
      }
    }
  }
}