rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function userExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function currentUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && userExists() &&
        currentUserData().get('userRole', '') == 'admin';
    }

    function isBanned() {
      return isSignedIn() && userExists() &&
        currentUserData().get('banned', false) == true;
    }

    function isActive() {
      return isSignedIn() && !isBanned();
    }

    // USERS collection
    match /users/{userId} {
      // Allow users to read their own data so they can check their status
      allow read: if isSignedIn() && (isOwner(userId) || isAdmin());
      // But only active users or admins can read OTHER users' data
      allow list: if isActive();

      allow create: if isSignedIn() && isOwner(userId);
      // Owner/admin can update anything; active users can only increment engagement fields on others
      allow update: if !isBanned() && (
        isOwner(userId) ||
        isAdmin() ||
        (isActive() && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['points', 'totalLikesReceived', 'badges']))
      );
      allow delete: if isAdmin();
    }

    // POINTS HISTORY (gamification transactions)
    match /pointsHistory/{userId}/transactions/{transactionId} {
      allow read: if isActive() && (isOwner(userId) || isAdmin());
      allow create: if isActive();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // THREADS collection
    match /threads/{threadId} {
      allow read: if isActive();
      allow create: if isActive();
      allow update: if isActive() && (
        isAdmin() ||
        // Owner can edit content fields only — not pinned, likeCount, etc.
        (resource.data.authorId == request.auth.uid &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['title', 'content', 'editedAt'])) ||
        // Any member can react (reactions map field)
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['reactions']) ||
        // Any member can update commentCount (on add/delete comment)
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['commentCount'])
      );
      allow delete: if (isOwner(resource.data.authorId) || isAdmin()) && !isBanned();

      // COMMENTS subcollection
      match /comments/{commentId} {
        allow read: if isActive();
        allow create: if isActive();
        allow update: if isActive() && (
          isAdmin() ||
          // Owner can only edit content, not authorId or createdAt
          (resource.data.authorId == request.auth.uid &&
            request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['content', 'editedAt']))
        );
        allow delete: if (isOwner(resource.data.authorId) || isAdmin()) && !isBanned();
      }
    }

    // COURSES collection
    match /courses/{courseId} {
      allow read: if isActive();
      allow write: if isAdmin();

      match /lessons/{lessonId} {
        allow read: if isActive();
        allow write: if isAdmin();
      }
    }

    // USER PROGRESS
    match /userProgress/{progressId} {
      allow read: if isActive() && (
        progressId.matches(request.auth.uid + '_.*') || isAdmin()
      );
      allow create: if isActive() &&
        request.resource.data.userId == request.auth.uid;
      allow update: if isActive() && (
        progressId.matches(request.auth.uid + '_.*') || isAdmin()
      );
      allow delete: if isAdmin();
    }

    // TOOLS collection
    match /tools/{toolId} {
      allow read: if isActive();
      allow write: if isAdmin();
    }

    // CLARITY SESSIONS
  match /clarity_sessions/{sessionId} {
  allow read: if isActive() && (
    resource.data.userId == request.auth.uid ||
    resource.data.clientEmail == request.auth.token.email ||
    resource.data.clientEmailLower == request.auth.token.email ||
    isAdmin()
  );
  allow create: if isActive();
  allow update: if isActive() && (
    resource.data.userId == request.auth.uid ||
    resource.data.clientEmail == request.auth.token.email ||
    isAdmin()
  );
  allow delete: if isAdmin();
}
match /spark_profiles/{sessionId} {
  allow get: if isActive() && (
    resource.data.userId == request.auth.uid ||
    resource.data.email == request.auth.token.email ||
    isAdmin()
  );
  allow list: if isActive() && (
    resource.data.userId == request.auth.uid ||
    resource.data.email == request.auth.token.email ||
    isAdmin()
  );
  allow create: if isActive();
  allow update: if isActive() && (
    resource.data.userId == request.auth.uid ||
    resource.data.email == request.auth.token.email ||
    isAdmin()
  );
  allow delete: if isAdmin();
}
match /spark_results/{resultId} {
  allow get: if isActive() && (
    resource.data.userId == request.auth.uid ||
    resource.data.accountEmail == request.auth.token.email ||
    isAdmin()
  );
  allow list: if isActive() && (
    resource.data.userId == request.auth.uid ||
    resource.data.accountEmail == request.auth.token.email ||
    isAdmin()
  );
  allow create: if isActive();
  allow update: if isActive() && (
    resource.data.userId == request.auth.uid ||
    resource.data.accountEmail == request.auth.token.email ||
    isAdmin()
  );
  allow delete: if isAdmin();
}
    // AUDIENCE TOOL
   match /audience_tool/{sessionId} {
  allow get: if isActive() && (
    resource.data.userId == request.auth.uid ||
    resource.data.email == request.auth.token.email ||
    isAdmin()
  );
  allow list: if isActive() && (
    resource.data.userId == request.auth.uid ||
    resource.data.email == request.auth.token.email ||
    isAdmin()
  );
  allow create: if isActive();
  allow update: if isActive() && (
    resource.data.userId == request.auth.uid ||
    resource.data.email == request.auth.token.email ||
    isAdmin()
  );
  allow delete: if isAdmin();
}
  match /audience_results/{resultId} {
  allow get: if isActive() && (
    resource.data.userId == request.auth.uid ||
    resource.data.accountEmail == request.auth.token.email ||
    isAdmin()
  );
  allow list: if isActive() && (
    resource.data.userId == request.auth.uid ||
    resource.data.accountEmail == request.auth.token.email ||
    isAdmin()
  );
  allow create: if isActive();
  allow update: if isActive() && (
    resource.data.userId == request.auth.uid ||
    resource.data.accountEmail == request.auth.token.email ||
    isAdmin()
  );
  allow delete: if isAdmin();
}
match /breakthrough_sessions/{sessionId} {
  allow read: if isActive() && (
    resource.data.userId == request.auth.uid || isAdmin()
  );
  allow create: if isActive();
  allow update: if isActive() && (
    resource.data.userId == request.auth.uid || isAdmin()
  );
  allow delete: if isAdmin();
}

match /value_reports/{reportId} {
  allow read: if isActive() && (
    resource.data.userId == request.auth.uid || isAdmin()
  );
  allow create: if isActive();
  allow update: if isAdmin();
  allow delete: if isAdmin();
}

match /journey_sessions/{sessionId} {
  allow read: if isActive() && (
    resource.data.userId == request.auth.uid || isAdmin()
  );
  allow create: if isActive();
  allow update: if isActive() && (
    resource.data.userId == request.auth.uid || isAdmin()
  );
  allow delete: if isAdmin();
}

match /spark_council_sessions/{sessionId} {
  allow read: if isActive() && (
    resource.data.userId == request.auth.uid || isAdmin()
  );
  allow create: if isActive() &&
    request.resource.data.userId == request.auth.uid;
  allow update: if isActive() && (
    resource.data.userId == request.auth.uid || isAdmin()
  );
  allow delete: if isAdmin();
}

match /breakthrough_public_results/{sessionId} {
  allow read: if isActive() && (
    resource.data.userId == request.auth.uid || isAdmin()
  );
  allow create: if isActive() &&
    request.resource.data.userId == request.auth.uid;
  allow update: if isActive() && (
    resource.data.userId == request.auth.uid || isAdmin()
  );
  allow delete: if isAdmin();
}

match /graduation_requests/{requestId} {
  allow read: if isActive() && (
    resource.data.userId == request.auth.uid || isAdmin()
  );
  allow create: if isActive();
  allow update: if isAdmin();
  allow delete: if isAdmin();
}
    // EVENTS
    match /Events/{eventId} {
      allow read: if isActive();
      allow write: if isAdmin();
    }

    match /pastEvents/{eventId} {
      allow read: if isActive();
      allow write: if isAdmin();
    }

    // SETTINGS
    match /settings/{settingId} {
      allow read: if isActive();
      allow write: if isAdmin();
    }

    // CLIENT RESULTS
    match /clientresults/{resultId} {
      allow read: if isActive() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow create: if isActive();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // AUDIT REPORTS
    match /Audit_reports/{reportId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // TECHSTACK RESULTS
    match /techstack_results/{resultId} {
      allow read: if isActive() && (
        resource.data.userId == request.auth.uid ||
        resource.data.accountEmail == request.auth.token.email ||
        isAdmin()
      );
      allow create: if isActive() &&
        request.resource.data.userId == request.auth.uid;
      allow update: if isActive() &&
        resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }

    // JOURNEY MAPS (certification tool output — keyed by uid)
    match /journey_maps/{userId} {
      allow read: if isActive() && (isOwner(userId) || isAdmin());
      allow create: if isActive() && isOwner(userId);
      allow update: if isActive() && isOwner(userId);
      allow delete: if isAdmin();
    }

    // OFFER SORT RESULTS (keyed by uid)
    match /offer_sort_results/{userId} {
      allow read: if isActive() && (isOwner(userId) || isAdmin());
      allow create: if isActive() && isOwner(userId);
      allow update: if isActive() && isOwner(userId);
      allow delete: if isAdmin();
    }

    // OFFER BUILDER RESULTS (keyed by uid)
    match /offer_results/{userId} {
      allow read: if isActive() && (isOwner(userId) || isAdmin());
      allow create: if isActive() && isOwner(userId);
      allow update: if isActive() && isOwner(userId);
      allow delete: if isAdmin();
    }

    // FUNNEL GENERATOR RESULTS (keyed by uid)
    match /funnel_generator_results/{userId} {
      allow read: if isActive() && (isOwner(userId) || isAdmin());
      allow create: if isActive() && isOwner(userId);
      allow update: if isActive() && isOwner(userId);
      allow delete: if isAdmin();
    }

    // SALES PAGE RESULTS / SALES COPY (keyed by uid)
    match /sales_page_results/{userId} {
      allow read: if isActive() && (isOwner(userId) || isAdmin());
      allow create: if isActive() && isOwner(userId);
      allow update: if isActive() && isOwner(userId);
      allow delete: if isAdmin();
    }

    // OPT-IN PAGE RESULTS (keyed by uid)
    match /optin_page_results/{userId} {
      allow read: if isActive() && (isOwner(userId) || isAdmin());
      allow create: if isActive() && isOwner(userId);
      allow update: if isActive() && isOwner(userId);
      allow delete: if isAdmin();
    }

    // CERTIFICATION PROGRESS (keyed by uid)
    match /certification_progress/{userId} {
      allow read: if isActive() && (isOwner(userId) || isAdmin());
      allow create: if isActive() && isOwner(userId);
      allow update: if isActive() && (isOwner(userId) || isAdmin());
      allow delete: if isAdmin();
    }

    // EMAIL SEQUENCES (keyed by uid)
    match /email_sequences/{userId} {
      allow read: if isActive() && (isOwner(userId) || isAdmin());
      allow create: if isActive() && isOwner(userId);
      allow update: if isActive() && isOwner(userId);
      allow delete: if isAdmin();
    }

    // PROMPT RESULTS
    match /prompt_results/{userId} {
      allow read: if isActive() && (isOwner(userId) || isAdmin());
      allow create: if isActive() && isOwner(userId) &&
        request.resource.data.userId == request.auth.uid;
      allow update: if isActive() && isOwner(userId);
      allow delete: if isAdmin();
    }

    // AGENT SESSIONS
    match /agent_sessions/{sessionId} {
      allow read: if isActive() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow create: if isActive() &&
        request.resource.data.userId == request.auth.uid;
      allow update: if isActive() &&
        resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }

   // CONVERSATIONS (direct messages)
match /conversations/{conversationId} {
  allow read: if isActive() &&
    request.auth.uid in resource.data.participants;
  allow create: if isActive() &&
    request.auth.uid in request.resource.data.participants;
  allow update: if isActive() &&
    request.auth.uid in resource.data.participants;
  allow delete: if isAdmin();

  match /messages/{messageId} {
    allow read: if isActive() &&
      request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
    allow create: if isActive() &&
      exists(/databases/$(database)/documents/conversations/$(conversationId)) &&
      request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
    allow update: if isActive() &&
      resource.data.senderId == request.auth.uid;
    allow delete: if isAdmin();
  }
}

    // MARKETPLACE LISTINGS (public marketplace)
    match /marketplace_listings/{listingId} {
      // Anyone can browse — no login required
      allow read: if true;

      // Only certified members can submit (status must be 'pending')
      allow create: if isSignedIn() &&
        currentUserData().get('certified', false) == true &&
        request.resource.data.builderUserId == request.auth.uid &&
        request.resource.data.status == 'pending';

      allow update: if isAdmin() ||
        // Signed-in users can increment useCount by exactly 1
        (isSignedIn() &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['useCount']) &&
          request.resource.data.useCount == resource.data.useCount + 1) ||
        // Listing owner can edit content fields (not status, builderUserId, useCount)
        (isActive() &&
          resource.data.builderUserId == request.auth.uid &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['name', 'description', 'link', 'category', 'tags', 'updatedAt']));

      allow delete: if isAdmin();
    }

    // COMMUNITY POSTS (graduation announcements etc.)
    match /communityPosts/{postId} {
      allow read: if isActive();
      allow create: if isActive();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // LESSON PACKAGES (admin-only — lesson generator output)
    match /lesson_packages/{docId} {
      allow read, write: if isAdmin();
    }

    // LESSON PLANS (admin-only — lesson package page form data)
    match /lesson_plans/{docId} {
      allow read, write: if isAdmin();
    }

    // ADMIN LESSON SCRIPTS (admin-only — screen recorder script output)
    match /admin_lesson_scripts/{docId} {
      allow read, write: if isAdmin();
    }

    // MEMBER LESSON PACKAGES (member course creation tool)
    match /member_lesson_packages/{docId} {
      allow read: if isActive() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isActive() && request.resource.data.userId == request.auth.uid;
      allow update: if isActive() && resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }

    // AGENT KNOWLEDGE BASE (admin-managed, read by Build Agent)
    match /agent_knowledge/{docId} {
      allow read: if isActive();
      allow write: if isAdmin();
    }

    // VALUE TOOL (Roadblock 8 — Value Mirror)
    match /value_tool/{docId} {
      allow read: if isActive() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isActive() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // HUBS (creator hub configs — read publicly for hub pages, write by owner)
    match /hubs/{hubSlug} {
      allow read: if true;
      allow create: if isActive() && request.resource.data.owner == request.auth.uid;
      allow update: if isActive() && (resource.data.owner == request.auth.uid || isAdmin());
      allow delete: if isAdmin();

      match /pages/{pageId} {
        allow read: if pageId == "sales";
        allow create, update: if isActive() &&
          (get(/databases/$(database)/documents/hubs/$(hubSlug)).data.owner == request.auth.uid || isAdmin());
        allow delete: if isAdmin() ||
          (isActive() && get(/databases/$(database)/documents/hubs/$(hubSlug)).data.owner == request.auth.uid);
      }

      // Secrets sub-collection — API keys; readable only by Cloud Functions via Admin SDK
      match /secrets/{docId} {
        allow read, write: if false;
      }
    }

    // WAITLIST (public signups — no auth required)
    match /waitlist/{email} {
      allow create, update: if true;
      allow read, delete: if isAdmin();
    }

    // API USAGE (admin-only cost tracking)
    match /api_usage/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ADMIN ALERTS (Just Sparked etc.)
    match /admin_alerts/{alertId} {
      allow create: if isActive();
      allow read: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // LESSON PROJECTS
    match /lesson_projects/{projectId} {
      allow read: if isAdmin() || (isActive() && resource.data.userId == request.auth.uid);
      allow create: if isActive() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin() || (isActive() && resource.data.userId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // SOCIAL SCHEDULER (31-day post planner — one doc per user, keyed by uid)
    match /social_scheduler/{userId} {
      allow read, write: if isActive() && isOwner(userId);
      allow read: if isAdmin();
    }

    // NOTIFICATIONS
    match /notifications/{notificationId} {
      allow read: if isActive() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      // Users can only create notifications targeted at themselves; admins can create for anyone
      allow create: if isActive() && (
        request.resource.data.userId == request.auth.uid || isAdmin()
      );
      allow update: if isActive() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow delete: if isAdmin();
    }
  }
}
