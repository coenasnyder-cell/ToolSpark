rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function userExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function currentUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && userExists() &&
        currentUserData().get('userRole', '') == 'admin';
    }

    function isBanned() {
      return isSignedIn() && userExists() &&
        currentUserData().get('userRole', '') == 'banned';
    }

    function isActive() {
      return isSignedIn() && !isBanned();
    }

    // USERS collection
    match /users/{userId} {
      // Allow users to read their own data so they can check their status
      allow read: if isSignedIn() && (isOwner(userId) || isAdmin());
      // But only active users or admins can read OTHER users' data
      allow list: if isActive();

      allow create: if isSignedIn() && isOwner(userId);
      allow update: if (isOwner(userId) || isAdmin()) && !isBanned();
      allow delete: if isAdmin();
    }

    // THREADS collection
    match /threads/{threadId} {
      allow read: if isActive();
      allow create: if isActive();
      allow update: if isActive();
      allow delete: if (isOwner(resource.data.authorId) || isAdmin()) && !isBanned();

      // COMMENTS subcollection
      match /comments/{commentId} {
        allow read: if isActive();
        allow create: if isActive();
        allow update: if isActive() && (
          resource.data.authorId == request.auth.uid || isAdmin()
        );
        allow delete: if (isOwner(resource.data.authorId) || isAdmin()) && !isBanned();
      }
    }

    // COURSES collection
    match /courses/{courseId} {
      allow read: if isActive();
      allow write: if isAdmin();

      match /lessons/{lessonId} {
        allow read: if isActive();
        allow write: if isAdmin();
      }
    }

    // USER PROGRESS
    match /userProgress/{progressId} {
      allow read: if isActive() && (
        progressId.matches(request.auth.uid + '_.*') || isAdmin()
      );
      allow create: if isActive() &&
        request.resource.data.userId == request.auth.uid;
      allow update: if isActive() && (
        progressId.matches(request.auth.uid + '_.*') || isAdmin()
      );
      allow delete: if isAdmin();
    }

    // TOOLS collection
    match /tools/{toolId} {
      allow read: if isActive();
      allow write: if isAdmin();
    }

    // CLARITY SESSIONS
    match /clarity_sessions/{sessionId} {
      allow read: if isActive() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow create: if isActive();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // EVENTS
    match /Events/{eventId} {
      allow read: if isActive();
      allow write: if isAdmin();
    }

    // SETTINGS
    match /settings/{settingId} {
      allow read: if isActive();
      allow write: if isAdmin();
    }

    // CLIENT RESULTS
    match /clientresults/{resultId} {
      allow read: if isActive() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow create: if isActive();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // AUDIT REPORTS
    match /Audit_reports/{reportId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // NOTIFICATIONS
    match /notifications/{notificationId} {
      allow read: if isActive() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow create: if isActive();
      allow update: if isActive() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow delete: if isAdmin();
    }
  }
}
