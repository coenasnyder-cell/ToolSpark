rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.userRole == 'admin';
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow write: if signedIn() && request.auth.uid == userId;
    }

    match /settings/{docId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /courses/{courseId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();

      match /lessons/{lessonId} {
        allow read: if signedIn();
        allow create, update, delete: if isAdmin();
      }
    }

    match /userProgress/{progressId} {
      allow create: if signedIn() &&
        request.resource.data.userId == request.auth.uid;
      allow read: if signedIn() &&
        (resource == null || resource.data.userId == request.auth.uid);
      allow update, delete: if signedIn() &&
        resource != null && resource.data.userId == request.auth.uid;
    }

    match /threads/{threadId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update: if signedIn() && (
        request.auth.uid == resource.data.authorId ||
        isAdmin() ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions'])
      );
      allow delete: if signedIn() && (
        request.auth.uid == resource.data.authorId ||
        isAdmin()
      );

      match /comments/{commentId} {
        allow read: if signedIn();
        allow create: if signedIn();
        allow update: if signedIn() && (
          request.auth.uid == resource.data.authorId ||
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions'])
        );
        allow delete: if signedIn() && request.auth.uid == resource.data.authorId;
      }
    }

    match /clarity_sessions/{sessionId} {
      allow read, write: if true;
    }

    match /clientresults/{docId} {
      allow read, write: if true;
    }

    match /Audit_reports/{docId} {
      allow read, write: if true;
    }

    match /Events/{eventId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }
  }
}
