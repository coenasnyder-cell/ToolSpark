rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function userExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function currentUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && userExists() &&
        currentUserData().get('userRole', '') == 'admin';
    }

    function isBanned() {
      return isSignedIn() && userExists() &&
        currentUserData().get('banned', false) == true;
    }

    function isActive() {
      return isSignedIn() && !isBanned();
    }

    // USERS collection
    match /users/{userId} {
      // Allow users to read their own data so they can check their status
      allow read: if isSignedIn() && (isOwner(userId) || isAdmin());
      // But only active users or admins can read OTHER users' data
      allow list: if isActive();

      allow create: if isSignedIn() && isOwner(userId);
      // Owner/admin can update anything; active users can only increment engagement fields on others
      allow update: if !isBanned() && (
        isOwner(userId) ||
        isAdmin() ||
        (isActive() && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['points', 'totalLikesReceived', 'badges']))
      );
      allow delete: if isAdmin();
    }

    // POINTS HISTORY (gamification transactions)
    match /pointsHistory/{userId}/transactions/{transactionId} {
      allow read: if isActive() && (isOwner(userId) || isAdmin());
      allow create: if isActive();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // THREADS collection
    match /threads/{threadId} {
     allow read: if isActive();
  allow create: if isActive();
  allow update: if isActive() && (
    resource.data.authorId == request.auth.uid ||
    isAdmin()
  );
  allow delete: if (isOwner(resource.data.authorId) || isAdmin()) && !isBanned();

      // COMMENTS subcollection
      match /comments/{commentId} {
        allow read: if isActive();
        allow create: if isActive();
        allow update: if isActive() && (
          resource.data.authorId == request.auth.uid || isAdmin()
        );
        allow delete: if (isOwner(resource.data.authorId) || isAdmin()) && !isBanned();
      }
    }

    // COURSES collection
    match /courses/{courseId} {
      allow read: if isActive();
      allow write: if isAdmin();

      match /lessons/{lessonId} {
        allow read: if isActive();
        allow write: if isAdmin();
      }
    }

    // USER PROGRESS
    match /userProgress/{progressId} {
      allow read: if isActive() && (
        progressId.matches(request.auth.uid + '_.*') || isAdmin()
      );
      allow create: if isActive() &&
        request.resource.data.userId == request.auth.uid;
      allow update: if isActive() && (
        progressId.matches(request.auth.uid + '_.*') || isAdmin()
      );
      allow delete: if isAdmin();
    }

    // TOOLS collection
    match /tools/{toolId} {
      allow read: if isActive();
      allow write: if isAdmin();
    }

    // CLARITY SESSIONS
    match /clarity_sessions/{sessionId} {
  allow read: if true;
  allow create: if true;
  allow update: if true;
  allow delete: if isAdmin();
}
match /spark_profiles/{sessionId} {
  allow get: if true;
  allow list: if isAdmin() || (
    isActive() &&
    resource.data.email == request.auth.token.email
  );
  allow create: if true;
  allow update: if isAdmin() || (
    isActive() &&
    request.resource.data.userId == request.auth.uid
  );
  allow delete: if isAdmin();
}
match /spark_results/{resultId} {
  allow read: if isActive() && (
    resource.data.userId == request.auth.uid ||
    resource.data.accountEmail == request.auth.token.email ||
    isAdmin()
  );
  allow create: if isActive();
  allow update: if isActive() && (
    resource.data.userId == request.auth.uid || isAdmin()
  );
  allow delete: if isAdmin();
}

    // AUDIENCE TOOL
    match /audience_tool/{sessionId} {
      allow get: if true;
      allow list: if isAdmin() || (
        isActive() &&
        resource.data.email == request.auth.token.email
      );
      allow create: if true;
      allow update: if isAdmin() || (
        isActive() &&
        request.resource.data.userId == request.auth.uid
      );
      allow delete: if isAdmin();
    }

    match /audience_results/{resultId} {
      allow read: if isActive() && (
        resource.data.userId == request.auth.uid ||
        resource.data.accountEmail == request.auth.token.email ||
        isAdmin()
      );
      allow create: if isActive();
      allow update: if isActive() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow delete: if isAdmin();
    }

    // EVENTS
    match /Events/{eventId} {
      allow read: if isActive();
      allow write: if isAdmin();
    }

    match /pastEvents/{eventId} {
      allow read: if isActive();
      allow write: if isAdmin();
    }

    // SETTINGS
    match /settings/{settingId} {
      allow read: if isActive();
      allow write: if isAdmin();
    }

    // CLIENT RESULTS
    match /clientresults/{resultId} {
      allow read: if isActive() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow create: if isActive();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // AUDIT REPORTS
    match /Audit_reports/{reportId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // TECHSTACK RESULTS
    match /techstack_results/{resultId} {
      allow read: if isActive() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow create: if isActive() &&
        request.resource.data.userId == request.auth.uid;
      allow update: if isActive() &&
        resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }

    // PROMPT RESULTS
    match /prompt_results/{userId} {
      allow read: if isActive() && (isOwner(userId) || isAdmin());
      allow create: if isActive() && isOwner(userId) &&
        request.resource.data.userId == request.auth.uid;
      allow update: if isActive() && isOwner(userId);
      allow delete: if isAdmin();
    }

    // AGENT SESSIONS
    match /agent_sessions/{sessionId} {
      allow read: if isActive() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow create: if isActive() &&
        request.resource.data.userId == request.auth.uid;
      allow update: if isActive() &&
        resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }

   // CONVERSATIONS (direct messages)
match /conversations/{conversationId} {
  allow read: if isActive() &&
    request.auth.uid in resource.data.participants;
  allow create: if isActive() &&
    request.auth.uid in request.resource.data.participants;
  allow update: if isActive() &&
    request.auth.uid in resource.data.participants;
  allow delete: if isAdmin();

  match /messages/{messageId} {
    allow read: if isActive() &&
      request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
    allow create: if isActive() &&
      exists(/databases/$(database)/documents/conversations/$(conversationId)) &&
      request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
    allow update: if isActive() &&
      resource.data.senderId == request.auth.uid;
    allow delete: if isAdmin();
  }
}

    // WAITLIST (public signups — no auth required)
    match /waitlist/{email} {
      allow create, update: if true;
      allow read, delete: if isAdmin();
    }

    // ADMIN ALERTS (Just Sparked etc.)
    match /admin_alerts/{alertId} {
      allow create: if isActive();
      allow read: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // NOTIFICATIONS
    match /notifications/{notificationId} {
      allow read: if isActive() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow create: if isActive();
      allow update: if isActive() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow delete: if isAdmin();
    }
  }
}
