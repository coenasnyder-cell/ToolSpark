rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function userExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function currentUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && userExists() &&
        currentUserData().get('userRole', '') == 'admin';
    }

    function isBanned() {
      return isSignedIn() && userExists() &&
        currentUserData().get('banned', false) == true;
    }

    // USERS collection
    // Anyone signed in can read profiles
    // Only owner or admin can write
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // THREADS collection
    match /threads/{threadId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isOwner(resource.data.authorId) || isAdmin();

      // COMMENTS subcollection
      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow update: if isSignedIn() && (
          resource.data.authorId == request.auth.uid || isAdmin()
        );
        allow delete: if isOwner(resource.data.authorId) || isAdmin();
      }
    }

    // COURSES collection
    // Anyone signed in can read
    // Only admin can write
    match /courses/{courseId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();

      // LESSONS subcollection
      match /lessons/{lessonId} {
        allow read: if isSignedIn();
        allow write: if isAdmin();
      }
    }

    // USER PROGRESS
    // Only owner or admin can read/write
    match /userProgress/{progressId} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow create: if isSignedIn() && 
        request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow delete: if isAdmin();
    }

    // TOOLS collection
    // Anyone signed in can read
    // Only admin can write
    match /tools/{toolId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // CLARITY SESSIONS
    // Only owner or admin can read
    // Anyone signed in can create
    match /clarity_sessions/{sessionId} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow create: if isSignedIn();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // EVENTS
    // Anyone signed in can read
    // Only admin can write
    match /Events/{eventId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // SETTINGS
    // Anyone signed in can read
    // Only admin can write
    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // CLIENT RESULTS
    // Only owner or admin can read
    match /clientresults/{resultId} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow create: if isSignedIn();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // AUDIT REPORTS
    // Only admin can read/write
    match /Audit_reports/{reportId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // NOTIFICATIONS
    match /notifications/{notificationId} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow delete: if isAdmin();
    }
  }
}